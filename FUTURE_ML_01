import pandas as pd
import matplotlib.pyplot as plt
from sklearn.linear_model import LinearRegression

# Load dataset
df = pd.read_csv("sales.csv")

# Convert Date column to datetime
df["Date"] = pd.to_datetime(df["Date"])

# Convert date to numerical value
df["Day"] = (df["Date"] - df["Date"].min()).dt.days

# Features and target
X = df[["Day"]]
y = df["Sales"]

# Train model
model = LinearRegression()
model.fit(X, y)

# Predict next 30 days
future_days = pd.DataFrame({
    "Day": range(df["Day"].max() + 1, df["Day"].max() + 31)
})

predictions = model.predict(future_days)

# Create future dates
future_dates = pd.date_range(
    start=df["Date"].max() + pd.Timedelta(days=1),
    periods=30
)

# Display predictions
forecast = pd.DataFrame({
    "Date": future_dates,
    "Predicted Sales": predictions
})

print("\nSales Forecast for Next 30 Days:\n")
print(forecast)

# Plot results
plt.figure(figsize=(12,6))
plt.plot(df["Date"], df["Sales"], label="Actual Sales", marker="o")
plt.plot(future_dates, predictions, label="Forecasted Sales", linestyle="--", marker="x")
plt.title("Sales Forecast")
plt.xlabel("Date")
plt.ylabel("Sales")
plt.legend()
plt.grid(True)
plt.show()